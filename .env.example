# Copy to .env (docker compose) or .env.local (local `go run`), then fill in.

# bcrypt hash of the login password. Generate it with:
#   go run ./cmd/password    # prints the hash (edit the literal inside first)
APP_PASSWD=<bcrypt-hash>

# Random secret used to sign JWTs. Keep it stable and secret. Generate e.g.:
#   openssl rand -base64 32
JWT_SECRET=<random-string>
